# Copy this file to apps/data/.env for local development.
# Real secrets must live outside git (GitHub Secrets / local .env).
PETROCAST_DW_HOST=localhost
PETROCAST_DW_PORT=5432
PETROCAST_DW_USER=petrocast
PETROCAST_DW_PASSWORD=change-me
PETROCAST_DW_DATABASE=petrocast
PETROCAST_SOURCE_PRODUCTION_URL=https://datos.gob.ar/dataset/energia-produccion-petroleo-gas-por-pozo-capitulo-iv/archivo/energia_b5b58cdc-9e07-41f9-b392-fb9ec68b0725
PETROCAST_SOURCE_WELLS_URL=https://datos.gob.ar/dataset/energia-produccion-petroleo-gas-por-pozo-capitulo-iv/archivo/energia_cbfa4d79-ffb3-4096-bab5-eb0dde9a8385
PETROCAST_NOTIFICATION_WEBHOOK_URL=
PETROCAST_MLFLOW_TRACKING_URI=http://mlflow:5000
PETROCAST_MLFLOW_EXPERIMENT_NAME=petrocast-production-forecast
PETROCAST_MLFLOW_MODEL_NAME=petrocast-production
PETROCAST_MLFLOW_MODEL_ALIAS=champion
PETROCAST_ML_ARTIFACT_DIR=/opt/dagster/dagster_home/ml-artifacts
PETROCAST_GIT_SHA=unknown

# ── MLflow tracking / registry — contrato C (ADR-0032, F3-08) ────────────────
# Frozen names; consumed by F3-14 (run logging) and F3-19 (retraining job).
# Dagster receives the PETROCAST_MLFLOW_* values above. Replace the tracking
# URI when using the shared team backend.
# Backend compartido en la nube (Neon/Supabase/RDS); fallback local:
#   postgresql://petrocast:<password>@localhost:5432/mlflow
# MLFLOW_TRACKING_URI=postgresql://USER:PASSWORD@HOST:5432/mlflow?sslmode=require
# MLFLOW_EXPERIMENT_NAME=petrocast-production-forecast
# Registered model: petrocast-production — champion via alias @champion.
# Artefactos (server --default-artifact-root / artifact_location):
# PETROCAST_MLFLOW_ARTIFACT_ROOT=s3://<artifacts-bucket>/mlflow
# Credenciales S3 para artefactos (el fallback local no las necesita). Provienen
# del login AWS SSO (la SCP de la org prohibe IAM users) → incluir session token:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-2  # region del bucket petrocast-ml-artifacts (env shared)
