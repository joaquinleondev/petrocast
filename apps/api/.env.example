API_KEY=abcdef12345

# Data-warehouse connection (mirrors PETROCAST_DW_* from the data stack).
# In Docker Compose, these are set to point at data-postgres.
DW_HOST=localhost
DW_PORT=5432
DW_USER=petrocast
DW_PASSWORD=petrocast
DW_DATABASE=petrocast

# ── MLflow tracking / registry — contrato C (ADR-0032, F3-08) ────────────────
# Frozen names; consumed by F3-18 (champion loader:
# models:/petrocast-production@champion). COMMENTED OUT until F3-18 adds the
# reserved ML block to core/config.py: Settings uses extra="forbid" and would
# reject unknown keys in the .env file.
# MLFLOW_TRACKING_URI=postgresql://USER:PASSWORD@HOST:5432/mlflow?sslmode=require
# Credenciales S3 desde AWS SSO (la SCP de la org prohibe IAM users) → session token:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-2  # region del bucket petrocast-ml-artifacts (env shared)
