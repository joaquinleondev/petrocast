API_KEY=abcdef12345

# Data-warehouse connection (mirrors PETROCAST_DW_* from the data stack).
# In Docker Compose, these are set to point at data-postgres.
DW_HOST=localhost
DW_PORT=5432
DW_USER=petrocast
DW_PASSWORD=petrocast
DW_DATABASE=petrocast

# ── ML serving — champion loader (F3-18, contratos B/C) ──────────────────────
# MLflow tracking/registry server the API resolves models:/<name>@<alias> from.
# Frozen names (ADR-0032): the champion URI is models:/petrocast-production@champion.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_MODEL_NAME=petrocast-production
MLFLOW_MODEL_ALIAS=champion
# Downloading the model artifact may need S3 creds from AWS SSO (the org SCP
# forbids IAM users) — read directly by MLflow/boto, not by Settings:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-2  # region of petrocast-ml-artifacts (env shared)
